{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "cd frontend && NEXT_PUBLIC_SYNAPSE_API=http://localhost:8766 NEXT_PUBLIC_SYNAPSE_WS=ws://localhost:8766/ws/session pnpm dev --port 3000"
      ],
      "port": 3000
    },
    {
      "name": "frontend-verify",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "cd frontend && NEXT_PUBLIC_SYNAPSE_API=http://localhost:8765 NEXT_PUBLIC_SYNAPSE_WS=ws://localhost:8765/ws/session pnpm dev"
      ],
      "autoPort": true
    }
  ]
}
